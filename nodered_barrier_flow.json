    {
        "id":  "fn-cmd-parse",
        "type":  "function",
        "z":  "tab-barrier",
        "name":  "Parse command",
        "func":  "var cmd = {};\ntry {\n    cmd = (typeof msg.payload === \u0027string\u0027) ? JSON.parse(msg.payload) : msg.payload;\n} catch(e) {\n    node.error(\u0027Bad JSON: \u0027 + msg.payload);\n    return null;\n}\nvar action = cmd.action || \u0027?\u0027;\nvar dir = cmd.direction || \u0027?\u0027;\nmsg.payload = \u0027Barrier \u0027 + (action === \u0027OPEN\u0027 ? \u0027OPENED\u0027 : action) + \u0027. Direction: \u0027 + dir;\nreturn msg;",
        "outputs":  1,
        "timeout":  0,
        "noerr":  0,
        "initialize":  "",
        "finalize":  "",
        "libs":  [

                 ],
        "x":  430,
