    {
        "id":  "fn-random-in",
        "type":  "function",
        "z":  "tab-barrier",
        "name":  "Random plate IN",
        "func":  "var plates = [\"A777BC\", \"B123KZ\", \"K555MK\", \"X000XX\", \"GUEST01\"];\nvar plate = plates[Math.floor(Math.random() * plates.length)];\nvar direction = \"IN\";\nvar motionMsg = {\n    payload: JSON.stringify({\n        sensor_id: \"motion-main\",\n        type: \"BARRIER_MOTION\",\n        gate_id: \"main-gate\",\n        status: \"DETECTED\",\n        direction: direction\n    }),\n    topic: \"smartresidency/barrier/motion\"\n};\nvar cameraMsg = {\n    payload: JSON.stringify({\n        sensor_id: \"camera-main\",\n        type: \"BARRIER_CAMERA\",\n        gate_id: \"main-gate\",\n        direction: direction,\n        plate_number: plate,\n        confidence: parseFloat((0.85 + Math.random() * 0.14).toFixed(2)),\n        status: \"RECOGNIZED\"\n    }),\n    topic: \"smartresidency/barrier/camera/plate\"\n};\nnode.warn(\"[barrier] random IN: plate=\" + plate);\nreturn [motionMsg, cameraMsg];",
        "outputs":  2,
        "timeout":  0,
        "noerr":  0,
        "initialize":  "",
        "finalize":  "",
        "libs":  [

                 ],
        "x":  430,
        "y":  100,
